generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String                 @id @default(cuid())
  name       String
  email      String                 @unique
  password   String
  boards     Board[]                @relation("UserBoards") // owned boards
  cards      Card[]                 @relation("CardMembers") // assigned to cards
  comments   Comment[]
  meetings   MeetingParticipant[]
}

model Board {
  id         String                 @id @default(cuid())
  title      String
  ownerId    String
  owner      User                  @relation("UserBoards", fields: [ownerId], references: [id])
  lists      List[]
  meetings   Meeting[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model List {
  id         String                 @id @default(cuid())
  title      String
  boardId    String
  board      Board                 @relation(fields: [boardId], references: [id])
  cards      Card[]
  position   Int
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model Card {
  id          String                @id @default(cuid())
  title       String
  description String?
  listId      String
  list        List                 @relation(fields: [listId], references: [id])
  position    Int
  members     User[]               @relation("CardMembers")
  labels      Label[]              @relation("CardLabels") 
  comments    Comment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model Label {
  id      String                   @id @default(cuid())
  name    String
  color   String
  cards   Card[]                  @relation("CardLabels")
}

model Comment {
  id         String                @id @default(cuid())
  message    String
  cardId     String
  card       Card                 @relation(fields: [cardId], references: [id])
  authorId   String
  author     User                 @relation(fields: [authorId], references: [id])
  createdAt  DateTime             @default(now())
}

model Meeting {
  id           String              @id @default(cuid())
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime
  boardId      String
  board        Board               @relation(fields: [boardId], references: [id])
  participants MeetingParticipant[]
  createdAt    DateTime            @default(now())
}

model MeetingParticipant {
  id         String                @id @default(cuid())
  userId     String
  meetingId  String
  user       User                 @relation(fields: [userId], references: [id])
  meeting    Meeting              @relation(fields: [meetingId], references: [id])
}
